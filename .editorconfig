# EditorConfig — https://editorconfig.org
# Keeps line endings, indent, and trailing-whitespace handling consistent
# across editors (VSCode, Cursor, vim, JetBrains, ...).

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown: trailing spaces are sometimes meaningful (line breaks).
[*.md]
trim_trailing_whitespace = false

# YAML / JSON / JS / TS: 2-space convention.
[*.{yml,yaml,json,js,ts,jsx,tsx}]
indent_size = 2

# Makefiles MUST use real tabs.
[Makefile]
indent_style = tab

# Go uses tabs.
[*.go]
indent_style = tab
